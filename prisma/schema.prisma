generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ads {
  id          String   @id
  name        String
  type        AdType
  imageUrl    String?
  htmlCode    String?
  targetUrl   String?
  slot        AdSlot
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  targetPages String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model ai_usage_logs {
  id           String   @id
  userId       String
  userName     String
  feature      String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  articleTitle String?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model articles {
  id                String            @id
  title             String
  slug              String            @unique
  content           String
  excerpt           String?
  featuredImage     String?
  status            ArticleStatus     @default(DRAFT)
  verificationLabel VerificationLabel @default(UNVERIFIED)
  readTime          Int?
  viewCount         Int               @default(0)
  publishedAt       DateTime?
  scheduledAt       DateTime?
  seoTitle          String?
  seoDescription    String?
  authorId          String
  categoryId        String
  reviewNote        String?
  reviewedBy        String?
  reviewedAt        DateTime?
  assignedEditorId  String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  users             users             @relation(fields: [authorId], references: [id])
  categories        categories        @relation(fields: [categoryId], references: [id])
  comments          comments[]
  corrections       corrections[]
  reports           reports[]
  revisions         revisions[]
  sources           sources[]
  tags              tags[]            @relation("ArticleToTag")

  @@index([assignedEditorId])
  @@index([authorId])
  @@index([categoryId])
  @@index([publishedAt])
  @@index([status])
}

model audit_logs {
  id        String   @id
  action    String
  entity    String
  entityId  String
  detail    String?
  userId    String
  ip        String?
  createdAt DateTime @default(now())
  users     users    @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
}

model categories {
  id          String     @id
  name        String     @unique
  slug        String     @unique
  description String?
  icon        String?
  order       Int        @default(0)
  articles    articles[]
}

model comments {
  id          String   @id
  content     String
  authorName  String
  authorEmail String
  isApproved  Boolean  @default(false)
  articleId   String
  parentId    String?
  createdAt   DateTime @default(now())
  articles    articles @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model corrections {
  id          String   @id
  description String
  articleId   String
  createdAt   DateTime @default(now())
  articles    articles @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model media {
  id           String   @id
  filename     String
  url          String
  type         String
  size         Int
  uploadedBy   String
  uploaderName String
  createdAt    DateTime @default(now())

  @@index([uploadedBy])
}

model notifications {
  id        String   @id
  userId    String
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, isRead])
}

model reports {
  id        String       @id
  reason    ReportReason
  detail    String?
  email     String?
  status    ReportStatus @default(PENDING)
  articleId String
  createdAt DateTime     @default(now())
  articles  articles     @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model revisions {
  id        String   @id
  content   String
  title     String
  changedBy String
  articleId String
  createdAt DateTime @default(now())
  articles  articles @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model sources {
  id          String   @id
  name        String
  title       String?
  institution String?
  url         String?
  articleId   String
  articles    articles @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model system_settings {
  id    String @id
  key   String @unique
  value String
}

model contact_messages {
  id        String   @id
  name      String
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model tags {
  id       String     @id
  name     String     @unique
  slug     String     @unique
  articles articles[] @relation("ArticleToTag")
}

model users {
  id               String       @id
  email            String       @unique
  password         String
  name             String
  avatar           String?
  bio              String?
  role             Role         @default(JOURNALIST)
  specialization   String?
  phone            String?
  nomorKartuPers   String?
  organisasiPers   String?
  pendidikan       String?
  pengalaman       String?
  keahlian         String?
  portofolio       String?
  mediaSosial      String?
  alamat           String?
  isActive         Boolean      @default(true)
  twoFactorEnabled Boolean      @default(false)
  activeSessionId  String?
  lastLoginAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime
  articles         articles[]
  audit_logs       audit_logs[]
}

enum AdSlot {
  HEADER
  SIDEBAR
  IN_ARTICLE
  FOOTER
  POPUP
  FLOATING_BOTTOM
}

enum AdType {
  IMAGE
  GIF
  HTML
}

enum ArticleStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ReportReason {
  HOAX
  INACCURATE
  SARA
  DEFAMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum Role {
  SUPER_ADMIN
  CHIEF_EDITOR
  EDITOR
  SENIOR_JOURNALIST
  JOURNALIST
  CONTRIBUTOR
}

enum VerificationLabel {
  VERIFIED
  UNVERIFIED
  CORRECTION
  OPINION
}
